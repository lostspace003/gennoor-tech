# Email Service Configuration
# Choose one of the following email services:

# Option 1: SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Option 2: SMTP (Hostinger or any SMTP provider)
SMTP_HOST=mail.gennoor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@gennoor.com
SMTP_PASS=your_smtp_password_here

# Option 3: Resend
RESEND_API_KEY=your_resend_api_key_here

# Option 4: AWS SES
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Email Addresses Configuration
EMAIL_FROM_TRAINING=training@gennoor.com
EMAIL_FROM_INFO=info@gennoor.com
EMAIL_FROM_SALES=sales@gennoor.com
EMAIL_FROM_SCHEDULE=schedule@gennoor.com
EMAIL_FROM_ENQUIRY=enquiry@gennoor.com
EMAIL_FROM_SUPPORT=customercare@gennoor.com
EMAIL_FROM_WEBINAR=webinar@gennoor.com
EMAIL_FROM_MARKETING=marketing@gennoor.com

# Admin & Notification Emails
EMAIL_ADMIN=admin@gennoor.com
EMAIL_CEO=jalalceo@gennoor.com
EMAIL_HR=hr@gennoor.com
EMAIL_ESCALATION=escalation@gennoor.com

# CC Settings
CC_SALES_ON_TRAINING=true
CC_ENQUIRY_ON_CERTIFICATION=true

# Notification Settings
ADMIN_NOTIFICATIONS_ENABLED=true
SEND_USER_CONFIRMATION=true
SEND_PDF_ATTACHMENTS=true

# Lead Scoring Thresholds (in days)
HOT_LEAD_DAYS=30
WARM_LEAD_DAYS=60

# Follow-up Settings
ENABLE_AUTO_FOLLOWUP=true
FOLLOWUP_DELAY_HOURS=24

# WhatsApp Business API (Optional)
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER=+919326352241

# Microsoft Graph / Bookings Integration
# Register an app in Azure AD (Entra ID) → App registrations
# Required API permissions (Application): Bookings.ReadWrite.All, BookingsAppointment.ReadWrite.All
MS_GRAPH_TENANT_ID=your_tenant_id
MS_GRAPH_CLIENT_ID=your_client_id
MS_GRAPH_CLIENT_SECRET=your_client_secret
MS_BOOKINGS_BUSINESS_ID=your_booking_business_email@gennoor.com

# CRM Integration (Optional)
CRM_ENABLED=false
CRM_API_KEY=your_crm_api_key
CRM_ENDPOINT=https://your-crm.com/api

# Database URL (for storing enquiries)
DATABASE_URL=postgresql://user:password@localhost:5432/gennoor_enquiries

# Application Settings
NEXT_PUBLIC_SITE_URL=https://www.gennoor.com
NODE_ENV=production

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your_mixpanel_token

# Security
JWT_SECRET=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# Rate Limiting
RATE_LIMIT_ENABLED=true
MAX_REQUESTS_PER_MINUTE=10

# File Storage (for PDFs)
PDF_STORAGE_PATH=./email-attachments
MAX_ATTACHMENT_SIZE_MB=10

# Email Templates Path
EMAIL_TEMPLATES_PATH=./email-templates

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/gennoor-tech.log